# PrepEdge environment variables (copy to .env)

# Required for JWT authentication (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# Seed credentials (used on first `db:seed` in Docker / local setup)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=password123
SEED_USER_EMAIL=user@example.com
SEED_USER_PASSWORD=password123

# Backend
FRONTEND_ORIGIN=http://localhost:5173
ALLOW_MOCK_BILLING=true
FORCE_SSL=false

# Optional: local Ollama for live AI responses (falls back to simulated content if unavailable)
# OLLAMA_HOST=http://localhost:11434

# Frontend (production builds only; leave empty when using Vite dev proxy)
# VITE_API_BASE_URL=http://localhost:3005

# Production Kamal/Docker deploy (optional)
# RAILS_MASTER_KEY=
# DATABASE_URL=postgres://user:pass@host:5432/prepedge_production
